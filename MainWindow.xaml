<Window x:Class="Musicsync"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicSync"
        mc:Ignorable="d"
        Title="Music Sync!" Height="400" Width="600" WindowStyle="ToolWindow" ResizeMode="NoResize" Icon="/musicsync.png" WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style TargetType="Button">

            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border
                    x:Name="Boton"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="0">

                            <ContentPresenter
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter
                            TargetName="Boton"
                            Property="Background"
                            Value="#505050"/>

                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">

                                <Setter
                            TargetName="Boton"
                            Property="Background"
                            Value="#00A2FF"/>

                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">

                                <Setter
                            TargetName="Boton"
                            Property="Opacity"
                            Value="0.5"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black"/>
                <GradientStop Color="#FF110505" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="19*"/>
            <ColumnDefinition Width="319*"/>
            <ColumnDefinition Width="62*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Margin="20,20,20,10" Grid.ColumnSpan="3">

            <TextBlock
            Text="Sincronizar Música de Android"
            FontSize="24"
            Margin="0,0,0,10" Foreground="#FFDC5C5C" FontFamily="Eras ITC"/>

            <TextBlock
            Text="Conecta un teléfono al pc en modo MTP (Media Transfer Protocol)"
            FontSize="15" Foreground="#FFFFA6A6" FontFamily="Eras ITC"
            />

            <TextBlock
            Text="Teléfono conectado:"
            FontWeight="Bold"
            Margin="0,10,0,0" Foreground="#FFC36363" FontFamily="Eras ITC"/>

            <TextBlock
            Name="TxtDispositivo"
            Text="Esperando a que lo conectes..."
            FontStyle="Oblique" Foreground="White" FontFamily="Eras ITC"
            />

            <TextBlock
            Text="Carpeta de música del teléfono:"
            FontWeight="Bold"          
            Margin="0,10,0,0" Foreground="#FFC36363" FontFamily="Eras ITC"/>

            <TextBlock
            Name="TxtCarpeta2"
            FontStyle="Oblique"
            Text="Esperando..."
            Margin="0,0,0,0" Foreground="White" FontFamily="Eras ITC"/>

            <ComboBox
            Name="CmbCarpetasAndroid"
            Margin="0,5,0,10"
            Visibility="Collapsed"/>

            <Button
            Name="BtnCambiarCarpeta2"
            Content="Cambiar carpeta"
            Width="100"
            Height="20"
            HorizontalAlignment="Left" Background="#FF292929" BorderBrush="#FF898989" Foreground="#FFBBBBBB" OpacityMask="Red"
            />

            <TextBlock
            Text="Carpeta de música del pc:"
            FontWeight="Bold"          
            Margin="0,30,0,0" Foreground="#FFC36363" FontFamily="Eras ITC"/>

            <TextBlock
            Name="TxtCarpeta"
            FontStyle="Oblique"
            Text="Esperando..."
            Margin="0,0,0,0" Foreground="White" FontFamily="Eras ITC"/>
            <Button
            x:Name="BtnCambiarCarpeta"
            Content="Cambiar carpeta"
            Width="100"
            Height="20"
            Click="BtnCambiarCarpeta_Click" HorizontalAlignment="Left" Background="#FF292929" BorderBrush="#FF898989" Foreground="#FFBBBBBB"/>

            <Button
                Name="BtnComparar"
                Content="Comparar"
                Height="30" Width="96" Margin="0,25,300,0" Background="#FF292929" BorderBrush="#FF898989" Foreground="#FFBBBBBB"
                />
            <Button
        Name="BtnCopiar"
        Content="Copiar"
Height="19" Width="96" Margin="0,10,300,0" Background="#FFDC5C5C" BorderBrush="#FF898989" Foreground="White"/>
        </StackPanel>
        <StackPanel Margin="272,69,20,0" Grid.Column="1" Grid.ColumnSpan="2">

            <TextBlock
    Name="TxtAccionActual"
    Text="Esperando..."
    Margin="0,22,0,10" Foreground="#FFC36363" FontFamily="Eras ITC"/>

            <ListBox
    Name="LstRegistro"
    Height="200" Foreground="White" BorderBrush="#FF111111">
                <ListBox.Background>
                    <ImageBrush ImageSource="/bglista.png"/>
                </ListBox.Background>
            </ListBox>
            <ProgressBar
    x:Name="PrgSync"
    Height="25"
    Minimum="0"
    Maximum="100" Background="#FF1A1A1A" Foreground="#FFB00606" BorderBrush="#FF111111"/>

        </StackPanel>
    </Grid>
</Window>
